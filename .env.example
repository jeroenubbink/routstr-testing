# Copy to .env (gitignored) and fill in as needed.

# Funded cashu token for payment tests, and the mint it was issued by.
E2E_CASHU_TOKEN=
CASHU_MINTS=https://mint.chorus.community

# Real upstream — nodes auto-seed an `openrouter` provider when this is set.
OPENROUTER_API_KEY=
OPENROUTER_REFERER=https://routstr-testing.local
UPSTREAM_MODELS_PATH=/providers-models/openrouter.json

# Admin passwords (needed for routstr-cli node config). Default: test-admin-pw
NODE_A_ADMIN_PASSWORD=test-admin-pw
NODE_B_ADMIN_PASSWORD=test-admin-pw

# Paid-scenario auth (per run, not stored):
#   NODE_A_API_KEY   — funded node api-key/cashu token for `real_inference`
#   X_CASHU_TOKENS   — comma-separated funded tokens for `xcashu`
